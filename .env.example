# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# ── Pluggy Open Finance ───────────────────────────────────
# Crie sua conta em https://dashboard.pluggy.ai
# Em sandbox, use os conectores de teste disponíveis no widget
PLUGGY_CLIENT_ID=your-pluggy-client-id
PLUGGY_CLIENT_SECRET=your-pluggy-client-secret

# ── MetaMask / Etherscan ─────────────────────────────────
# Crie sua chave gratuita em https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your-etherscan-api-key

# ── IA (Groq) ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://walletiq-nine.vercel.app
